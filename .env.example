# Local development examples
EXPO_PUBLIC_API_URL=http://localhost:4000/api
EXPO_PUBLIC_WS_URL=http://localhost:4000
EXPO_PUBLIC_CONTROL_API_URL=http://localhost:4010/api

# Android emulator examples
# EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api
# EXPO_PUBLIC_WS_URL=http://10.0.2.2:4000
# EXPO_PUBLIC_CONTROL_API_URL=http://10.0.2.2:4010/api

# Production examples
# EXPO_PUBLIC_API_URL=https://api.seudominio.com/api
# EXPO_PUBLIC_WS_URL=https://api.seudominio.com
# EXPO_PUBLIC_CONTROL_API_URL=https://control-api.seudominio.com/api

# Optional: set a real Expo/EAS project UUID only for builds with push configured
# EXPO_PUBLIC_PROJECT_ID=

# Logging level: error, warn, info, debug (default: warn in prod, debug in dev)
EXPO_PUBLIC_LOG_LEVEL=warn
EXPO_PUBLIC_APP_ENV=development

# API timeout in milliseconds (default: 30000, min: 5000, max: 120000)
EXPO_PUBLIC_API_TIMEOUT_MS=30000
